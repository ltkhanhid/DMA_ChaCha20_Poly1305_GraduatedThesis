$version
	QuestaSim Version 2024.1
$end
$timescale
	1ps
$end

$scope module uart_byte_tb $end
$var reg 1 ! clk $end
$var reg 1 " rst_n $end
$var reg 8 # tx_data [7:0] $end
$var reg 1 $ tx_send_en $end
$var reg 3 % tx_baud_set [2:0] $end
$var reg 1 & uart_wire $end
$var reg 1 ' tx_done $end
$var reg 1 ( tx_busy $end
$var reg 8 ) rx_data [7:0] $end
$var reg 1 * rx_done $end
$var reg 1 + rx_busy $end
$var reg 3 , rx_baud_set [2:0] $end
$var integer 32 - test_passed $end
$var integer 32 . test_failed $end

$scope task test_uart_loopback $end
$var reg 8 / data [7:0] $end
$upscope $end

$scope task test_back_to_back $end
$upscope $end

$scope task test_multiple_baud_rates $end
$upscope $end

$scope module u_tx $end
$var parameter 16 0 BPS_DR $end
$var wire 1 1 clk $end
$var wire 1 2 rst_n $end
$var wire 1 3 data_byte [7] $end
$var wire 1 4 data_byte [6] $end
$var wire 1 5 data_byte [5] $end
$var wire 1 6 data_byte [4] $end
$var wire 1 7 data_byte [3] $end
$var wire 1 8 data_byte [2] $end
$var wire 1 9 data_byte [1] $end
$var wire 1 : data_byte [0] $end
$var wire 1 ; send_en $end
$var reg 1 < uart_tx $end
$var reg 1 = tx_done $end
$var reg 1 > tx_busy $end
$var reg 16 ? div_cnt [15:0] $end
$var reg 1 @ bps_clk $end
$var reg 4 A bit_cnt [3:0] $end
$var reg 8 B tx_reg [7:0] $end
$var reg 2 C state_q [1:0] $end
$var reg 2 D state_d [1:0] $end
$upscope $end

$scope module u_rx $end
$var parameter 16 E BPS_DR $end
$var wire 1 F clk $end
$var wire 1 G rst_n $end
$var wire 1 H uart_rx $end
$var reg 8 I data_byte [7:0] $end
$var reg 1 J rx_done $end
$var reg 1 K rx_busy $end
$var reg 1 L rx_s1 $end
$var reg 1 M rx_s2 $end
$var reg 1 N rx_s2_prev $end
$var reg 1 O rx_negedge $end
$var reg 16 P div_cnt [15:0] $end
$var reg 1 Q bps_clk $end
$var reg 1 R start_bit_valid $end
$var reg 1 S reset_div_cnt $end
$var reg 2 T state_q [1:0] $end
$var reg 2 U state_d [1:0] $end
$var reg 4 V bit_cnt [3:0] $end
$var reg 8 W shift_reg [7:0] $end
$upscope $end
$upscope $end
$enddefinitions $end
